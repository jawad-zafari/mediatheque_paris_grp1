<?php
// Inclure la config avec les infos de connexion
require_once __DIR__ . '/../config/database.php'; // ../ car config est un dossier parent

// Inclure les fonctions DB
require_once __DIR__ . '/database.php'; // database.php est dans le même dossier core

// Données de l'admin
$name = "Super";
$last_name = "Admin";
$email = "admin@media.com";
$password = "Admin1234";
$role = "admin";

// Hashage du mot de passe
$hashed_password = password_hash($password, PASSWORD_DEFAULT);

// Insertion
$query = "INSERT INTO users (name, last_name, email, password, role) VALUES (?, ?, ?, ?, ?)";
$params = [$name, $last_name, $email, $hashed_password, $role];

if(db_execute($query, $params)) {
    echo "Compte admin créé avec succès !";
} else {
    echo "Erreur lors de la création du compte admin.";
}
